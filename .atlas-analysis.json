  "keyFeatures": [
    "Guided product planning and vision definition",
    "Data shape modeling and entity relationships",
    "Design system creation with Tailwind colors and Google Fonts",
    "Application shell and navigation design",
    "Section-by-section screen design with React components",
    "Sample data generation with TypeScript types",
    "Complete export package for implementation handoff",
    "Test-driven development specifications",
    "Props-based component architecture",
    "Light and dark mode support"
  ],
  "publicApiSurface": [
    "/product-vision - Define product overview, roadmap, and data shape",
    "/product-roadmap - Update product sections",
    "/data-shape - Update data entities and relationships",
    "/design-tokens - Choose colors and typography",
    "/design-shell - Design navigation and layout",
    "/shape-section - Define section spec and generate sample data",
    "/sample-data - Update sample data and types",
    "/design-screen - Create screen design components",
    "/screenshot-design - Capture screenshots of designs",
    "/export-product - Generate complete handoff package"
  ]
